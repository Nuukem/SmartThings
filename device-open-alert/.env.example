# SmartThings API Configuration
# Get your token from: https://account.smartthings.com/tokens
# ST "test token"
SMARTTHINGS_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# Pushover Notifications - Emergency Priority (pushes through silent phone)
# Get your User Key from: https://pushover.net
# Create an Application and get API Token from: https://pushover.net/apps
# Leave empty to disable Pushover notifications
PUSHOVER_USER_KEY=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# SmartThings Application API Token
PUSHOVER_API_TOKEN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# Pushover Priority (2=Emergency, 1=High, 0=Normal, -1=Low , -2=Lowest)
PUSHOVER_PRIORITY=2
# Pushover Sound (https://pushover.net/api#sounds)
PUSHOVER_SOUND=spacealarm

# Monitored Devices - JSON array of devices to check
# Format: {"id":"device-uuid","name":"Device Name","checkTime":"HH:MM","virtualDeviceId":"virtual-device-uuid"}
# - id: The actual door/sensor device ID
# - name: Display name for this device
# - checkTime: (Optional) Time to check device in 24-hour format HH:MM (default: 21:00 / 9pm)
#   Example times: "09:00" (9am), "17:30" (5:30pm), "21:00" (9pm)
# - virtualDeviceId: (Optional) Virtual switch turned on by a SmartThings routine to trigger a check
#
# MONITORED_DEVICES may be formatted across multiple lines for readability.
#
# Get device IDs using: get-device-ids.bat "your_token_here"
# 
# VIRTUAL DEVICE SETUP:
# Create virtual switch devices in SmartThings and name them something like "Garage Door Check"
# Add each virtual switch to your SmartThings routine and turn it ON.
# Subscribe this app to switch=on events for those virtual devices.
# When a virtual switch turns ON, the monitor checks the associated real device.
# If the real device is open, it sends a notification. It always resets the virtual switch to OFF.
#
# EXAMPLE: Check garage at 9pm, front door at 6pm, back door at 9pm
MONITORED_DEVICES=[
  {
    "id": "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx",
    "name": "Garage Door",
    "checkTime": "21:00",
    "virtualDeviceId": "vvvvvvvv-vvvv-vvvv-vvvv-vvvvvvvvvvvv"
  },
  {
    "id": "yyyyyyyy-yyyy-yyyy-yyyy-yyyyyyyyyyyy",
    "name": "Front Door",
    "checkTime": "18:00",
    "virtualDeviceId": "wwwwwwww-wwww-wwww-wwww-wwwwwwwwwwww"
  },
  {
    "id": "zzzzzzzz-zzzz-zzzz-zzzz-zzzzzzzzzzzz",
    "name": "Back Door",
    "checkTime": "21:00"
  }
]

# Optional: Legacy routine ID for the manual webhook endpoint.
# The SmartThings subscription flow uses MONITORED_DEVICES[].virtualDeviceId instead.
GO_TO_BED_ROUTINE_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Server port (for webhook endpoint)
PORT=3956

# Optional: Enable debug logging. Console info logs only show when this is exactly true.
DEBUG_LOGGING=false
